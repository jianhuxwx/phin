# API Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Gateway
GATE_AR_URL=https://gate.ar
GATE_AR_FALLBACK_URLS=https://arweave.net,https://g8way.io

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://phin:phin_dev@localhost:5432/phin

# Auth
JWT_SECRET=change_this_to_a_long_random_string_in_production

# CORS
CORS_ORIGINS=http://localhost:3000,https://phin.ar

# Rate Limiting
RATE_LIMIT_PUBLIC_MAX=60
RATE_LIMIT_WINDOW_MS=60000

